# PostgreSQL Configuration
POSTGRES_USER=doai_user
POSTGRES_PASSWORD=doai_password
POSTGRES_DB=doai_classroom
DATABASE_URL=postgresql://doai_user:doai_password@localhost:5432/doai_classroom

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# FastAPI Configuration
DEBUG=True
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# YOLO Configuration
YOLO_MODEL_VERSION=v8
YOLO_WEIGHTS_PATH=backend/models/yolo_weights/
YOLO_CONFIDENCE_THRESHOLD=0.5

# MQTT Configuration (Mosquitto Broker in Docker)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USE_MOCK=True
MQTT_TOPIC_PREFIX=classroom

# Performance & Risk Weights (Default)
PERFORMANCE_WEIGHTS_FILE=backend/config/performance_weights.json
RISK_WEIGHTS_FILE=backend/config/risk_weights.json

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000/api

# Embedded System / Gateway Configuration
ROOM_ID=                          # UUID of the target room (from database)
ROOM_CODE=B1-103                  # Room code for display
